<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.TX_ku" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:colorBackground">@color/window_background_launch</item>
        <item name="android:windowBackground">@color/window_background_launch</item>
        <!-- 避免首帧 Compose 尚未合成时透明系统栏下露出默认黑底（模拟器上易表现为整屏黑） -->
        <item name="android:statusBarColor">@color/window_background_launch</item>
        <item name="android:navigationBarColor">@color/window_background_launch</item>
        <!-- Android 15+ 对 targetSdk≥35 默认强制边到边；在全面适配前减少透明窗口导致的整屏发黑 -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
    </style>
</resources>