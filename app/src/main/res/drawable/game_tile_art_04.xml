<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:endColor="#FFB39DDB"
                android:startColor="#FF5E35B1"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:gravity="top|start"
        android:height="72dp"
        android:width="72dp">
        <shape android:shape="oval">
            <solid android:color="#45D1C4E9" />
        </shape>
    </item>
    <item
        android:width="152dp"
        android:height="152dp"
        android:drawable="@drawable/game_tile_motif_04"
        android:gravity="center" />
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#00000000"
                android:endColor="#72000000"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
