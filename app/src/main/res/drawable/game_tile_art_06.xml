<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="#FF4DB6AC"
                android:startColor="#FF00897B"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:gravity="center_horizontal|top"
        android:height="64dp"
        android:width="200dp">
        <shape android:shape="rectangle">
            <solid android:color="#25FFFFFF" />
        </shape>
    </item>
    <item
        android:width="152dp"
        android:height="152dp"
        android:drawable="@drawable/game_tile_motif_06"
        android:gravity="center" />
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#00000000"
                android:endColor="#6E000000"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
