<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#FFFF8A65"
                android:startColor="#FFE53935"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:gravity="center"
        android:height="140dp"
        android:width="140dp">
        <shape android:shape="oval">
            <solid android:color="#28FFEB3B" />
        </shape>
    </item>
    <item
        android:width="152dp"
        android:height="152dp"
        android:drawable="@drawable/game_tile_motif_03"
        android:gravity="center" />
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#00000000"
                android:endColor="#88000000"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
