<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="45"
                android:endColor="#FF80CBC4"
                android:startColor="#FF004D40"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:gravity="start|bottom"
        android:height="90dp"
        android:width="90dp">
        <shape android:shape="oval">
            <solid android:color="#30E0F2F1" />
        </shape>
    </item>
</layer-list>
