<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:endColor="#FFFFD54F"
                android:startColor="#FFE65100"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:gravity="end|bottom"
        android:height="92dp"
        android:width="92dp">
        <shape android:shape="oval">
            <solid android:color="#33FFAB40" />
        </shape>
    </item>
    <item
        android:width="152dp"
        android:height="152dp"
        android:drawable="@drawable/game_tile_motif_09"
        android:gravity="center" />
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:centerColor="#00000000"
                android:endColor="#80000000"
                android:startColor="#00000000"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
